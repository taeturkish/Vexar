  <script>
    // ==================== GITHUB AYARLARI ====================
    const GITHUB_TOKEN = 'YENİ_TOKEN_BURAYA'; // 👈 YENİ TOKEN'INI BURAYA YAZ
    const GITHUB_USERNAME = 'KULLANICI_ADIN'; // 👈 GITHUB KULLANICI ADIN
    const GITHUB_REPO = 'Vexar'; // 👈 REPO İSMİN
    const DATA_FILE = 'vexar-data.json';
    const BRANCH = 'main';

    // ==================== VERİ DEĞİŞKENLERİ ====================
    let users = [];
    let currentUser = JSON.parse(localStorage.getItem('vexarCurrentUser')) || null;
    let siteSettings = { activeServers: 0, systemStatus: 'Tüm Sistemler Çalışıyor', discountBanner: '🎉 AÇILIŞA ÖZEL FIRSATLAR! 🎉', testimonialsEnabled: false };
    let testimonials = [];
    let purchaseCodes = [];
    let categories = [];
    let packages = {};
    
    let currentCategory = 'minecraft';
    let selectedBillingCycle = 'sonsuz';
    let pendingPurchasePackage = null;
    let serverOnline = false;
    let currentTab = 'console';
    let panelData = { players: [], plugins: [], files: [] };
    let serverSettings = { serverName: 'VEXAR Sunucu', version: 'Paper 1.20.4', gamemode: 'Survival', difficulty: 'Normal', maxPlayers: '20', motd: 'Vexar Hosting Sunucusu' };

    // ==================== GITHUB API FONKSİYONLARI ====================
    async function loadFromGitHub() {
      showLoading();
      try {
        const response = await fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${GITHUB_REPO}/contents/${DATA_FILE}`, {
          headers: { 'Authorization': `token ${GITHUB_TOKEN}` }
        });
        
        if (response.ok) {
          const data = await response.json();
          const content = JSON.parse(atob(data.content));
          
          users = content.users || [];
          siteSettings = content.siteSettings || siteSettings;
          testimonials = content.testimonials || [];
          purchaseCodes = content.purchaseCodes || [];
          categories = content.categories || getDefaultCategories();
          packages = content.packages || getDefaultPackages();
        } else if (response.status === 404) {
          // Dosya yoksa varsayılanları kullan ve oluştur
          categories = getDefaultCategories();
          packages = getDefaultPackages();
          await saveToGitHub();
        } else {
          console.error('GitHub yükleme hatası:', response.status);
          loadFromLocalFallback();
        }
      } catch (e) {
        console.error('Bağlantı hatası:', e);
        loadFromLocalFallback();
      }
      hideLoading();
    }

    function loadFromLocalFallback() {
      categories = JSON.parse(localStorage.getItem('vexarCategories')) || getDefaultCategories();
      packages = JSON.parse(localStorage.getItem('vexarPackages')) || getDefaultPackages();
      siteSettings = JSON.parse(localStorage.getItem('vexarSiteSettings')) || siteSettings;
      testimonials = JSON.parse(localStorage.getItem('vexarTestimonials')) || [];
      purchaseCodes = JSON.parse(localStorage.getItem('vexarCodes')) || [];
      users = JSON.parse(localStorage.getItem('vexarUsers')) || [];
    }

    async function saveToGitHub() {
      showLoading();
      try {
        const content = {
          users, siteSettings, testimonials, purchaseCodes, categories, packages
        };
        
        // Önce mevcut dosyanın SHA'sını al
        let sha = null;
        try {
          const response = await fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${GITHUB_REPO}/contents/${DATA_FILE}`, {
            headers: { 'Authorization': `token ${GITHUB_TOKEN}` }
          });
          if (response.ok) {
            const data = await response.json();
            sha = data.sha;
          }
        } catch (e) {}
        
        const body = {
          message: 'Update Vexar data',
          content: btoa(JSON.stringify(content, null, 2)),
          branch: BRANCH
        };
        if (sha) body.sha = sha;
        
        const response = await fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${GITHUB_REPO}/contents/${DATA_FILE}`, {
          method: 'PUT',
          headers: {
            'Authorization': `token ${GITHUB_TOKEN}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(body)
        });
        
        if (!response.ok) {
          console.error('Kaydetme hatası:', response.status);
          saveToLocalFallback();
        }
      } catch (e) {
        console.error('Kaydetme hatası:', e);
        saveToLocalFallback();
      }
      hideLoading();
    }

    function saveToLocalFallback() {
      localStorage.setItem('vexarCategories', JSON.stringify(categories));
      localStorage.setItem('vexarPackages', JSON.stringify(packages));
      localStorage.setItem('vexarSiteSettings', JSON.stringify(siteSettings));
      localStorage.setItem('vexarTestimonials', JSON.stringify(testimonials));
      localStorage.setItem('vexarCodes', JSON.stringify(purchaseCodes));
      localStorage.setItem('vexarUsers', JSON.stringify(users));
    }

    function getDefaultCategories() {
      return [
        { id: 'minecraft', name: 'Minecraft Sunucu', icon: 'fa-cube', active: true },
        { id: 'ddos', name: 'DDoS Koruması', icon: 'fa-shield-alt', active: true },
        { id: 'anticheat', name: 'Hile Koruması', icon: 'fa-ban', active: true },
        { id: 'domain', name: 'Domain', icon: 'fa-globe', active: true }
      ];
    }

    function getDefaultPackages() {
      return {
        minecraft: {
          sonsuz: [
            { name: 'STARTER', desc: 'Çok Küçük Sunucular', cpu: '2 vCPU', ram: '4 GB', disk: '20 GB', price: 960 },
            { name: 'TEMEL', desc: 'Küçük Sunucular', cpu: '4 vCPU', ram: '8 GB', disk: '40 GB', price: 1990 },
            { name: 'ELITE', desc: 'Ortalama Sunucular', cpu: '6 vCPU', ram: '12 GB', disk: '60 GB', price: 2990 },
            { name: 'ULTRA', desc: 'Büyük Sunucular', cpu: '8 vCPU', ram: '16 GB', disk: '80 GB', price: 3990 },
            { name: 'TİTAN', desc: 'Çok Büyük Sunucular', cpu: '10 vCPU', ram: '24 GB', disk: '100 GB', price: 5500 },
            { name: 'MYTHIC', desc: '100 Oyuncu', cpu: '12 vCPU', ram: '32 GB', disk: '150 GB', price: 7200 },
            { name: 'LEGENDARY', desc: '300 Oyuncu', cpu: '24 vCPU', ram: '64 GB', disk: '300 GB', price: 11900 },
            { name: 'GALAXY', desc: '500 Oyuncu', cpu: '32 vCPU', ram: '128 GB', disk: '500 GB', price: 19900 },
            { name: 'UNIVERSE', desc: '600 Oyuncu', cpu: '48 vCPU', ram: '192 GB', disk: '750 GB', price: 29900 },
            { name: 'ETERNITY', desc: '800 Oyuncu', cpu: '64 vCPU', ram: '256 GB', disk: '1 TB', price: 35900 },
            { name: 'GOD', desc: '1000 Oyuncu', cpu: '128 vCPU', ram: '512 GB', disk: '2 TB', price: 59900 }
          ]
        },
        ddos: { aylik: [], yillik: [], sonsuz: [] },
        anticheat: { aylik: [], yillik: [], sonsuz: [] },
        domain: { sonsuz: [] }
      };
    }

    function showLoading() { document.getElementById('loadingOverlay').classList.add('active'); }
    function hideLoading() { document.getElementById('loadingOverlay').classList.remove('active'); }

    // ==================== SAYFA YÜKLEME ====================
    async function init() {
      await loadFromGitHub();
      applySiteSettings();
      renderUserAuth();
      renderCategories();
      selectCategory('minecraft');
      if (currentUser) {
        document.getElementById('adminBtn').style.display = isAdmin() ? 'flex' : 'none';
      }
    }

    function isAdmin() { return currentUser && currentUser.role === 'admin'; }

    function applySiteSettings() {
      document.getElementById('activeServers').textContent = siteSettings.activeServers;
      document.getElementById('systemStatus').textContent = siteSettings.systemStatus;
      document.getElementById('discountBanner').textContent = siteSettings.discountBanner;
      document.getElementById('testimonialsSection').style.display = siteSettings.testimonialsEnabled ? 'block' : 'none';
      if (siteSettings.testimonialsEnabled) renderTestimonials();
    }

    function renderUserAuth() {
      const section = document.getElementById('userAuthSection');
      if (currentUser) {
        section.innerHTML = `
          <div class="user-menu">
            <button class="user-btn" onclick="toggleUserMenu()"><i class="fas fa-user"></i> ${currentUser.username}</button>
            <div class="user-dropdown" id="userDropdown" style="position:absolute;top:40px;right:0;background:#1e1e2e;border-radius:12px;padding:8px;display:none;z-index:1000">
              <div onclick="openPanel()" style="padding:10px 14px;cursor:pointer"><i class="fas fa-server"></i> Sunucu Panelim</div>
              <div onclick="openCodeModal()" style="padding:10px 14px;cursor:pointer"><i class="fas fa-key"></i> Kod ile Giriş</div>
              <div onclick="logout()" style="padding:10px 14px;cursor:pointer"><i class="fas fa-sign-out-alt"></i> Çıkış Yap</div>
            </div>
          </div>
        `;
      } else {
        section.innerHTML = `
          <button class="user-btn" onclick="openLoginModal()"><i class="fas fa-sign-in-alt"></i> Giriş Yap</button>
          <button class="user-btn" onclick="openRegisterModal()"><i class="fas fa-user-plus"></i> Kayıt Ol</button>
        `;
      }
    }

    function toggleUserMenu() {
      const dd = document.getElementById('userDropdown');
      dd.style.display = dd.style.display === 'none' ? 'block' : 'none';
    }

    // ==================== AUTH İŞLEMLERİ ====================
    function openLoginModal() { document.getElementById('loginModal').classList.add('active'); }
    function closeLoginModal() { document.getElementById('loginModal').classList.remove('active'); }
    function openRegisterModal() { document.getElementById('registerModal').classList.add('active'); }
    function closeRegisterModal() { document.getElementById('registerModal').classList.remove('active'); }
    function switchToRegister() { closeLoginModal(); openRegisterModal(); }
    function switchToLogin() { closeRegisterModal(); openLoginModal(); }

    async function register() {
      const username = document.getElementById('registerUsername').value.trim();
      const email = document.getElementById('registerEmail').value.trim();
      const password = document.getElementById('registerPassword').value;
      const confirm = document.getElementById('registerPasswordConfirm').value;
      const error = document.getElementById('registerError');
      
      if (!username || !email || !password) { error.textContent = 'Tüm alanları doldurun!'; return; }
      if (password !== confirm) { error.textContent = 'Şifreler eşleşmiyor!'; return; }
      if (users.find(u => u.username === username)) { error.textContent = 'Bu kullanıcı adı zaten kullanılıyor!'; return; }
      
      const adminCode = prompt('Admin olmak için kodunuz var mı? (Varsa girin, yoksa boş bırakın)');
      const role = (adminCode === 'VEXAR2024') ? 'admin' : 'user';
      
      const newUser = { username, email, password, role, createdAt: new Date().toISOString() };
      users.push(newUser);
      
      currentUser = newUser;
      localStorage.setItem('vexarCurrentUser', JSON.stringify(currentUser));
      
      await saveToGitHub();
      
      closeRegisterModal();
      renderUserAuth();
      document.getElementById('adminBtn').style.display = role === 'admin' ? 'flex' : 'none';
      
      if (role === 'admin') alert('✅ Admin olarak kaydedildiniz!');
    }

    async function login() {
      const username = document.getElementById('loginUsername').value.trim();
      const password = document.getElementById('loginPassword').value;
      const error = document.getElementById('loginError');
      
      const user = users.find(u => u.username === username && u.password === password);
      if (!user) { error.textContent = 'Kullanıcı adı veya şifre hatalı!'; return; }
      
      currentUser = user;
      localStorage.setItem('vexarCurrentUser', JSON.stringify(currentUser));
      
      closeLoginModal();
      renderUserAuth();
      document.getElementById('adminBtn').style.display = isAdmin() ? 'flex' : 'none';
    }

    async function logout() {
      currentUser = null;
      localStorage.removeItem('vexarCurrentUser');
      renderUserAuth();
      document.getElementById('adminBtn').style.display = 'none';
      document.getElementById('userDropdown').style.display = 'none';
    }

    // ==================== KATEGORİ İŞLEMLERİ ====================
    function renderCategories() {
      const selector = document.getElementById('categorySelector');
      selector.innerHTML = categories.filter(c => c.active).map(cat => `
        <button class="category-btn ${currentCategory === cat.id ? 'active' : ''}" onclick="selectCategory('${cat.id}')">
          <i class="fas ${cat.icon}"></i> ${cat.name}
        </button>
      `).join('');
    }

    function selectCategory(catId) {
      currentCategory = catId;
      const cat = categories.find(c => c.id === catId);
      selectedBillingCycle = catId === 'domain' ? 'sonsuz' : 'sonsuz';
      renderCategories();
      renderPackages();
      document.getElementById('categoryTitle').textContent = cat ? cat.name + ' Paketleri' : 'Paketler';
    }

    // ==================== PAKET İŞLEMLERİ ====================
    function renderPackages() {
      const grid = document.getElementById('packagesGrid');
      const catPkgs = packages[currentCategory];
      if (!catPkgs) { grid.innerHTML = '<p style="color:#a1a1aa;text-align:center;grid-column:1/-1">Bu kategoride paket bulunmuyor.</p>'; return; }
      
      const pkgList = catPkgs[selectedBillingCycle] || catPkgs.sonsuz || [];
      const billingText = selectedBillingCycle === 'aylik' ? '/ Ay' : selectedBillingCycle === 'yillik' ? '/ Yıl' : '/ Sonsuz';
      
      if (pkgList.length === 0) { grid.innerHTML = '<p style="color:#a1a1aa;text-align:center;grid-column:1/-1">Bu kategoride paket bulunmuyor.</p>'; return; }
      
      grid.innerHTML = pkgList.map((pkg, i) => `
        <div class="package-card">
          <div class="package-header">
            <div class="package-name">VEXAR - ${pkg.name}</div>
            <div class="package-menu" onclick="togglePackageMenu(event, '${currentCategory}', '${selectedBillingCycle}', ${i})">
              <i class="fas fa-ellipsis-v"></i>
              <div class="package-menu-dropdown" id="menu-${currentCategory}-${selectedBillingCycle}-${i}">
                <div onclick="selectBillingCycle('aylik', '${currentCategory}')"><i class="fas fa-calendar"></i> Aylık</div>
                <div onclick="selectBillingCycle('yillik', '${currentCategory}')"><i class="fas fa-calendar-alt"></i> Yıllık</div>
                ${currentCategory !== 'domain' ? '<div onclick="selectBillingCycle(\'sonsuz\', \'' + currentCategory + '\')"><i class="fas fa-infinity"></i> Sonsuz</div>' : ''}
              </div>
            </div>
          </div>
          <div class="package-desc">${pkg.desc}</div>
          <ul class="package-specs">
            ${pkg.cpu ? `<li><i class="fas fa-microchip"></i> ${pkg.cpu} (Ryzen 9)</li>` : ''}
            ${pkg.ram ? `<li><i class="fas fa-memory"></i> ${pkg.ram} RAM</li>` : ''}
            ${pkg.disk ? `<li><i class="fas fa-hdd"></i> ${pkg.disk} NVMe SSD</li>` : ''}
            ${pkg.subdomain ? `<li><i class="fas fa-link"></i> ${pkg.subdomain}</li>` : ''}
            <li><i class="fas fa-map-pin"></i> İstanbul</li>
          </ul>
          <div class="price-section">
            <span class="discounted-price">${pkg.price} TL</span>
            <span class="price-period">${billingText}</span>
          </div>
          <button class="buy-btn" onclick="openPurchaseModal('${currentCategory}', '${selectedBillingCycle}', ${i})">
            <i class="fas fa-shopping-cart"></i> Satın Al
          </button>
        </div>
      `).join('');
    }

    function togglePackageMenu(event, cat, cycle, idx) {
      event.stopPropagation();
      document.querySelectorAll('.package-menu-dropdown').forEach(m => m.classList.remove('active'));
      document.getElementById(`menu-${cat}-${cycle}-${idx}`).classList.add('active');
    }

    function selectBillingCycle(cycle, cat) {
      selectedBillingCycle = cycle;
      currentCategory = cat;
      document.querySelectorAll('.package-menu-dropdown').forEach(m => m.classList.remove('active'));
      renderPackages();
    }

    function openPurchaseModal(cat, cycle, idx) {
      if (!currentUser) { openLoginModal(); return; }
      const pkg = packages[cat][cycle][idx];
      pendingPurchasePackage = { category: cat, package: pkg, packageName: pkg.name };
      document.getElementById('purchaseModalTitle').textContent = `Satın Al - ${pkg.name}`;
      document.getElementById('purchaseModal').classList.add('active');
    }

    function closePurchaseModal() {
      document.getElementById('purchaseModal').classList.remove('active');
      pendingPurchasePackage = null;
    }

    function openCodeModal() {
      if (!currentUser) { openLoginModal(); return; }
      document.getElementById('purchaseModal').classList.add('active');
      document.getElementById('purchaseModalTitle').textContent = 'Kod ile Giriş';
    }

    function checkPurchaseCode() {
      const code = document.getElementById('purchaseCodeCheckInput').value.trim().toUpperCase();
      const found = purchaseCodes.find(c => c.code === code);
      
      if (found) {
        currentPackage = { name: found.packageName, cpu: 'N/A', ram: 'N/A', disk: 'N/A' };
        closePurchaseModal();
        openPanel();
      } else {
        document.getElementById('purchaseError').textContent = 'Geçersiz satın alım kodu!';
      }
    }

    // ==================== YORUMLAR ====================
    function renderTestimonials() {
      const grid = document.getElementById('testimonialsGrid');
      if (!testimonials.length) {
        grid.innerHTML = '<p style="color:#a1a1aa;text-align:center;grid-column:1/-1">Henüz yorum bulunmuyor.</p>';
        return;
      }
      grid.innerHTML = testimonials.map(t => `
        <div class="package-card">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
            <div style="width:48px;height:48px;background:${t.color};border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700">${t.name[0]}</div>
            <div><h4>${t.name}</h4><p style="color:#a1a1aa;font-size:13px">${t.title}</p></div>
          </div>
          <div style="color:#d4d4d8;line-height:1.6;margin-bottom:16px">${t.comment}</div>
          <div style="color:#eab308">${'★'.repeat(t.rating)}${'☆'.repeat(5-t.rating)}</div>
        </div>
      `).join('');
    }

    // ==================== PANEL İŞLEMLERİ ====================
    function openPanel() {
      if (!currentUser) { openLoginModal(); return; }
      document.getElementById('mainPage').style.display = 'none';
      document.getElementById('panelPage').classList.add('active');
      document.getElementById('panelServerName').textContent = serverSettings.serverName;
      document.getElementById('panelServerSpecs').textContent = currentPackage ? `${currentPackage.cpu} | ${currentPackage.ram} | ${currentPackage.disk}` : 'Paket bilgisi';
      serverOnline = false;
      updateServerStatus();
      switchTab('console');
    }

    function logoutPanel() {
      document.getElementById('mainPage').style.display = 'block';
      document.getElementById('panelPage').classList.remove('active');
    }

    function updateServerStatus() {
      const badge = document.getElementById('serverStatusBadge');
      const text = document.getElementById('statusText');
      badge.className = serverOnline ? 'status-badge online' : 'status-badge';
      text.textContent = serverOnline ? 'Çevrimiçi' : 'Çevrimdışı';
    }

    function startServer() { serverOnline = true; updateServerStatus(); if (currentTab === 'console') switchTab('console'); }
    function stopServer() { serverOnline = false; updateServerStatus(); if (currentTab === 'console') switchTab('console'); }
    function restartServer() { stopServer(); setTimeout(() => startServer(), 1000); }

    function switchTab(tab) {
      currentTab = tab;
      document.querySelectorAll('.panel-tab').forEach(t => t.classList.remove('active'));
      event.target.closest('.panel-tab').classList.add('active');
      const content = document.getElementById('panelContent');
      
      if (tab === 'console') {
        content.innerHTML = `
          <div class="stats-grid">
            <div class="stat-card"><div class="stat-label">TPS</div><div class="stat-value">${serverOnline ? '20.0' : '0'}</div></div>
            <div class="stat-card"><div class="stat-label">RAM</div><div class="stat-value">${serverOnline ? '35%' : '0%'}</div></div>
            <div class="stat-card"><div class="stat-label">CPU</div><div class="stat-value">${serverOnline ? '12%' : '0%'}</div></div>
            <div class="stat-card"><div class="stat-label">Oyuncu</div><div class="stat-value">${panelData.players.length}</div></div>
          </div>
          <div class="console-output" id="consoleOutput">
            ${serverOnline ? '<div class="console-line"><span class="timestamp">[' + new Date().toLocaleTimeString() + ']</span> Sunucu başlatıldı.</div>' : '<div class="console-line">Sunucu çevrimdışı.</div>'}
          </div>
          <div class="console-input">
            <input type="text" placeholder="Komut girin..." id="consoleCommand" ${!serverOnline ? 'disabled' : ''}>
            <button class="submit-btn" style="width:auto" onclick="sendCommand()" ${!serverOnline ? 'disabled' : ''}>Gönder</button>
          </div>
        `;
      } else if (tab === 'network') {
        content.innerHTML = `
          <h3 style="margin-bottom:24px">Network İstatistikleri</h3>
          <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px">
            <div class="stat-card"><div class="stat-label">Ping</div><div class="stat-value">${serverOnline ? '0.8ms' : '0ms'}</div></div>
            <div class="stat-card"><div class="stat-label">Bant Genişliği</div><div class="stat-value">${serverOnline ? '8.2 Gbps' : '0 Gbps'}</div></div>
            <div class="stat-card"><div class="stat-label">DDoS Filtre</div><div class="stat-value">${serverOnline ? '1.2 Tbps' : '0 Tbps'}</div></div>
            <div class="stat-card"><div class="stat-label">Node Yükü</div><div class="stat-value">${serverOnline ? '34%' : '0%'}</div></div>
          </div>
        `;
      } else if (tab === 'settings') {
        content.innerHTML = `
          <h3 style="margin-bottom:24px">Sunucu Ayarları</h3>
          <div class="form-group"><label>Sunucu Adı</label><input type="text" id="settingName" value="${serverSettings.serverName}"></div>
          <div class="form-group"><label>Sürüm</label><select id="settingVersion">${['Paper 1.20.4','Purpur 1.20.4','Spigot 1.20.4'].map(v => `<option ${serverSettings.version===v?'selected':''}>${v}</option>`).join('')}</select></div>
          <div class="form-group"><label>Oyun Modu</label><select id="settingGamemode">${['Survival','Creative','Adventure'].map(g => `<option ${serverSettings.gamemode===g?'selected':''}>${g}</option>`).join('')}</select></div>
          <div class="form-group"><label>Zorluk</label><select id="settingDifficulty">${['Peaceful','Easy','Normal','Hard'].map(d => `<option ${serverSettings.difficulty===d?'selected':''}>${d}</option>`).join('')}</select></div>
          <div class="form-group"><label>Max Oyuncu</label><input type="number" id="settingMaxPlayers" value="${serverSettings.maxPlayers}"></div>
          <div class="form-group"><label>MOTD</label><input type="text" id="settingMotd" value="${serverSettings.motd}"></div>
          <button class="submit-btn" onclick="saveSettings()">Kaydet</button>
        `;
      } else {
        content.innerHTML = `<h3>${tab}</h3><p style="color:#a1a1aa">Bu bölüm yapım aşamasında.</p>`;
      }
    }

    function sendCommand() {
      const input = document.getElementById('consoleCommand');
      const output = document.getElementById('consoleOutput');
      if (input.value.trim() && serverOnline) {
        output.innerHTML += `<div class="console-line"><span class="timestamp">[${new Date().toLocaleTimeString()}]</span> > ${input.value}</div>`;
        input.value = '';
        output.scrollTop = output.scrollHeight;
      }
    }

    function saveSettings() {
      serverSettings.serverName = document.getElementById('settingName').value;
      serverSettings.version = document.getElementById('settingVersion').value;
      serverSettings.gamemode = document.getElementById('settingGamemode').value;
      serverSettings.difficulty = document.getElementById('settingDifficulty').value;
      serverSettings.maxPlayers = document.getElementById('settingMaxPlayers').value;
      serverSettings.motd = document.getElementById('settingMotd').value;
      document.getElementById('panelServerName').textContent = serverSettings.serverName;
      switchTab('settings');
    }

    // ==================== ADMIN PANELİ ====================
    function openAdminPanel() {
      if (!isAdmin()) return;
      document.getElementById('adminPanelModal').classList.add('active');
      switchAdminTab('categories');
    }

    function closeAdminPanelModal() { document.getElementById('adminPanelModal').classList.remove('active'); }

    function switchAdminTab(tab) {
      document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
      event.target.classList.add('active');
      const content = document.getElementById('adminTabContent');
      
      if (tab === 'categories') {
        content.innerHTML = `
          <button class="submit-btn" style="margin-bottom:20px" onclick="openCategoryForm()"><i class="fas fa-plus"></i> Kategori Ekle</button>
          <div id="categoriesList">
            ${categories.map((cat, i) => `
              <div class="category-item">
                <div><i class="fas ${cat.icon}"></i> ${cat.name} ${cat.active ? '' : '(Gizli)'}</div>
                <div class="category-actions">
                  <button class="edit-btn" onclick="openCategoryForm('${cat.id}')"><i class="fas fa-edit"></i></button>
                  <button class="delete-btn-sm" onclick="deleteCategory('${cat.id}')"><i class="fas fa-trash"></i></button>
                </div>
              </div>
            `).join('')}
          </div>
        `;
      } else if (tab === 'packages') {
        let html = '<button class="submit-btn" style="margin-bottom:20px" onclick="openPackageForm()"><i class="fas fa-plus"></i> Paket Ekle</button>';
        html += '<select id="adminPackageCategory" class="form-group" onchange="renderAdminPackages()">';
        html += categories.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
        html += '</select>';
        html += '<select id="adminPackageCycle" class="form-group" onchange="renderAdminPackages()"><option value="aylik">Aylık</option><option value="yillik">Yıllık</option><option value="sonsuz">Sonsuz</option></select>';
        html += '<div id="packagesList" style="margin-top:20px"></div>';
        content.innerHTML = html;
        renderAdminPackages();
      } else if (tab === 'codes') {
        content.innerHTML = `
          <button class="submit-btn" onclick="generateCode()"><i class="fas fa-plus"></i> Kod Oluştur</button>
          <div id="codesList" style="margin-top:20px"></div>
        `;
        renderCodesList();
      } else if (tab === 'testimonials') {
        content.innerHTML = `
          <div class="testimonials-toggle">
            <span>Yorumları Göster</span>
            <div class="toggle-switch ${siteSettings.testimonialsEnabled ? 'active' : ''}" onclick="toggleTestimonials()"></div>
          </div>
          <button class="submit-btn" onclick="addTestimonial()"><i class="fas fa-plus"></i> Yorum Ekle</button>
          <div id="testimonialsList" style="margin-top:20px"></div>
        `;
        renderTestimonialsList();
      } else if (tab === 'settings') {
        content.innerHTML = `
          <div class="form-group"><label>Aktif Sunucu Sayısı</label><input type="number" id="settingActiveServers" value="${siteSettings.activeServers}"></div>
          <div class="form-group"><label>Sistem Durumu</label><input type="text" id="settingSystemStatus" value="${siteSettings.systemStatus}"></div>
          <div class="form-group"><label>İndirim Banner Yazısı</label><input type="text" id="settingDiscountBanner" value="${siteSettings.discountBanner}"></div>
          <button class="submit-btn" onclick="saveSiteSettings()">Kaydet</button>
        `;
      } else if (tab === 'users') {
        content.innerHTML = `
          <h3>Kullanıcılar</h3>
          <div id="usersList">
            ${users.map((u, i) => `
              <div class="category-item">
                <div><strong>${u.username}</strong> (${u.email}) - ${u.role}</div>
                <div class="category-actions">
                  <select onchange="changeUserRole(${i}, this.value)">
                    <option value="user" ${u.role === 'user' ? 'selected' : ''}>User</option>
                    <option value="admin" ${u.role === 'admin' ? 'selected' : ''}>Admin</option>
                  </select>
                  <button class="delete-btn-sm" onclick="deleteUser(${i})"><i class="fas fa-trash"></i></button>
                </div>
              </div>
            `).join('')}
          </div>
        `;
      }
    }

    function renderAdminPackages() {
      const cat = document.getElementById('adminPackageCategory')?.value || 'minecraft';
      const cycle = document.getElementById('adminPackageCycle')?.value || 'sonsuz';
      const pkgs = packages[cat]?.[cycle] || [];
      const list = document.getElementById('packagesList');
      if (!list) return;
      list.innerHTML = pkgs.map((p, i) => `
        <div class="package-item">
          <div>${p.name} - ${p.price} TL</div>
          <div class="package-actions">
            <button class="edit-btn" onclick="openPackageForm('${cat}', '${cycle}', ${i})">Düzenle</button>
            <button class="delete-btn-sm" onclick="deletePackage('${cat}', '${cycle}', ${i})">Sil</button>
          </div>
        </div>
      `).join('');
    }

    function openCategoryForm(catId = null) {
      if (catId) {
        const cat = categories.find(c => c.id === catId);
        document.getElementById('categoryFormTitle').textContent = 'Kategori Düzenle';
        document.getElementById('categoryEditId').value = catId;
        document.getElementById('categoryName').value = cat.name;
        document.getElementById('categoryIcon').value = cat.icon;
        document.getElementById('categoryActive').checked = cat.active;
        document.getElementById('categoryDeleteBtn').style.display = 'block';
      } else {
        document.getElementById('categoryFormTitle').textContent = 'Kategori Ekle';
        document.getElementById('categoryEditId').value = '';
        document.getElementById('categoryName').value = '';
        document.getElementById('categoryIcon').value = 'fa-cube';
        document.getElementById('categoryActive').checked = true;
        document.getElementById('categoryDeleteBtn').style.display = 'none';
      }
      document.getElementById('categoryFormModal').classList.add('active');
    }

    function closeCategoryFormModal() { document.getElementById('categoryFormModal').classList.remove('active'); }

    async function saveCategory(e) {
      e.preventDefault();
      const id = document.getElementById('categoryEditId').value || 'cat_' + Date.now();
      const name = document.getElementById('categoryName').value;
      const icon = document.getElementById('categoryIcon').value;
      const active = document.getElementById('categoryActive').checked;
      
      const existingIndex = categories.findIndex(c => c.id === id);
      if (existingIndex >= 0) {
        categories[existingIndex] = { ...categories[existingIndex], name, icon, active };
      } else {
        categories.push({ id, name, icon, active });
        if (!packages[id]) packages[id] = { aylik: [], yillik: [], sonsuz: [] };
      }
      
      await saveToGitHub();
      closeCategoryFormModal();
      switchAdminTab('categories');
      renderCategories();
    }

    async function deleteCategory(catId) {
      if (confirm('Bu kategoriyi silmek istediğinize emin misiniz?')) {
        categories = categories.filter(c => c.id !== catId);
        delete packages[catId];
        await saveToGitHub();
        switchAdminTab('categories');
        renderCategories();
      }
    }

    function deleteCategoryConfirm() {
      const id = document.getElementById('categoryEditId').value;
      deleteCategory(id);
      closeCategoryFormModal();
    }

    function openPackageForm(cat = '', cycle = '', index = -1) {
      const categorySelect = document.getElementById('packageCategory');
      categorySelect.innerHTML = categories.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
      
      if (index >= 0) {
        const pkg = packages[cat][cycle][index];
        document.getElementById('packageFormTitle').textContent = 'Paket Düzenle';
        document.getElementById('packageEditIndex').value = index;
        document.getElementById('packageEditCategory').value = cat;
        document.getElementById('packageEditCycle').value = cycle;
        document.getElementById('packageName').value = pkg.name;
        document.getElementById('packageDesc').value = pkg.desc;
        document.getElementById('packageCpu').value = pkg.cpu || '';
        document.getElementById('packageRam').value = pkg.ram || '';
        document.getElementById('packageDisk').value = pkg.disk || '';
        document.getElementById('packageSubdomain').value = pkg.subdomain || '';
        document.getElementById('packagePrice').value = pkg.price;
        document.getElementById('packageCategory').value = cat;
        document.getElementById('packageCycle').value = cycle;
        document.getElementById('packageDeleteBtn').style.display = 'block';
      } else {
        document.getElementById('packageFormTitle').textContent = 'Paket Ekle';
        document.getElementById('packageEditIndex').value = '';
        document.getElementById('packageEditCategory').value = '';
        document.getElementById('packageEditCycle').value = '';
        document.getElementById('packageName').value = '';
        document.getElementById('packageDesc').value = '';
        document.getElementById('packageCpu').value = '';
        document.getElementById('packageRam').value = '';
        document.getElementById('packageDisk').value = '';
        document.getElementById('packageSubdomain').value = '';
        document.getElementById('packagePrice').value = '';
        document.getElementById('packageCategory').value = cat || 'minecraft';
        document.getElementById('packageCycle').value = cycle || 'sonsuz';
        document.getElementById('packageDeleteBtn').style.display = 'none';
      }
      document.getElementById('packageFormModal').classList.add('active');
    }

    function closePackageFormModal() { document.getElementById('packageFormModal').classList.remove('active'); }

    async function savePackage(e) {
      e.preventDefault();
      const editIndex = document.getElementById('packageEditIndex').value;
      const editCat = document.getElementById('packageEditCategory').value;
      const editCycle = document.getElementById('packageEditCycle').value;
      
      const cat = document.getElementById('packageCategory').value;
      const cycle = document.getElementById('packageCycle').value;
      
      const pkg = {
        name: document.getElementById('packageName').value,
        desc: document.getElementById('packageDesc').value,
        cpu: document.getElementById('packageCpu').value,
        ram: document.getElementById('packageRam').value,
        disk: document.getElementById('packageDisk').value,
        subdomain: document.getElementById('packageSubdomain').value,
        price: parseFloat(document.getElementById('packagePrice').value)
      };
      
      if (!packages[cat]) packages[cat] = { aylik: [], yillik: [], sonsuz: [] };
      if (!packages[cat][cycle]) packages[cat][cycle] = [];
      
      if (editIndex !== '' && editCat === cat && editCycle === cycle) {
        packages[cat][cycle][editIndex] = pkg;
      } else {
        if (editIndex !== '') packages[editCat][editCycle].splice(editIndex, 1);
        packages[cat][cycle].push(pkg);
      }
      
      await saveToGitHub();
      closePackageFormModal();
      switchAdminTab('packages');
      if (currentCategory === cat) selectCategory(cat);
    }

    async function deletePackage(cat, cycle, index) {
      if (confirm('Bu paketi silmek istediğinize emin misiniz?')) {
        packages[cat][cycle].splice(index, 1);
        await saveToGitHub();
        renderAdminPackages();
        if (currentCategory === cat) selectCategory(cat);
      }
    }

    function deletePackageConfirm() {
      const cat = document.getElementById('packageEditCategory').value;
      const cycle = document.getElementById('packageEditCycle').value;
      const index = document.getElementById('packageEditIndex').value;
      deletePackage(cat, cycle, index);
      closePackageFormModal();
    }

    async function generateCode() {
      const pkgName = prompt('Paket adı girin (örn: STARTER):');
      if (!pkgName) return;
      const code = 'VEX-' + Math.random().toString(36).substring(2,8).toUpperCase() + '-' + Math.random().toString(36).substring(2,6).toUpperCase();
      purchaseCodes.push({ code, packageName: pkgName, createdAt: new Date().toLocaleDateString('tr-TR') });
      await saveToGitHub();
      renderCodesList();
    }

    function renderCodesList() {
      const list = document.getElementById('codesList');
      if (!purchaseCodes.length) { list.innerHTML = '<p style="color:#a1a1aa">Kod yok</p>'; return; }
      list.innerHTML = purchaseCodes.map((c, i) => `
        <div class="code-item">
          <div><strong>${c.code}</strong><br><span style="color:#a1a1aa;font-size:13px">${c.packageName} - ${c.createdAt}</span></div>
          <button class="delete-btn-sm" onclick="deleteCode(${i})"><i class="fas fa-trash"></i></button>
        </div>
      `).join('');
    }

    async function deleteCode(i) { 
      purchaseCodes.splice(i, 1); 
      await saveToGitHub(); 
      renderCodesList(); 
    }

    async function toggleTestimonials() {
      siteSettings.testimonialsEnabled = !siteSettings.testimonialsEnabled;
      await saveToGitHub();
      applySiteSettings();
      switchAdminTab('testimonials');
    }

    async function addTestimonial() {
      const name = prompt('İsim:');
      const title = prompt('Başlık:');
      const comment = prompt('Yorum:');
      const rating = parseInt(prompt('Puan (1-5):'));
      if (name && comment && rating) {
        testimonials.push({ name, title, comment, rating, color: '#' + Math.floor(Math.random()*16777215).toString(16) });
        await saveToGitHub();
        renderTestimonialsList();
        applySiteSettings();
      }
    }

    function renderTestimonialsList() {
      const list = document.getElementById('testimonialsList');
      list.innerHTML = testimonials.map((t, i) => `
        <div class="testimonial-item">
          <div><strong>${t.name}</strong> - ${'★'.repeat(t.rating)}<br><span style="color:#a1a1aa">${t.comment.substring(0,50)}...</span></div>
          <button class="delete-btn-sm" onclick="deleteTestimonial(${i})"><i class="fas fa-trash"></i></button>
        </div>
      `).join('');
    }

    async function deleteTestimonial(i) { 
      testimonials.splice(i, 1); 
      await saveToGitHub(); 
      renderTestimonialsList(); 
      applySiteSettings(); 
    }

    async function saveSiteSettings() {
      siteSettings.activeServers = parseInt(document.getElementById('settingActiveServers').value) || 0;
      siteSettings.systemStatus = document.getElementById('settingSystemStatus').value;
      siteSettings.discountBanner = document.getElementById('settingDiscountBanner').value;
      await saveToGitHub();
      applySiteSettings();
      closeAdminPanelModal();
    }

    async function changeUserRole(index, role) {
      users[index].role = role;
      await saveToGitHub();
      if (currentUser && currentUser.username === users[index].username) {
        currentUser.role = role;
        localStorage.setItem('vexarCurrentUser', JSON.stringify(currentUser));
        document.getElementById('adminBtn').style.display = isAdmin() ? 'flex' : 'none';
      }
    }

    async function deleteUser(index) {
      if (confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?')) {
        users.splice(index, 1);
        await saveToGitHub();
        switchAdminTab('users');
      }
    }

    function showHome() { selectCategory('minecraft'); }
    function showPackages() { selectCategory('minecraft'); }

    // Init
    window.onclick = e => { 
      if (e.target.classList.contains('modal')) e.target.classList.remove('active');
      if (!e.target.closest('.package-menu')) document.querySelectorAll('.package-menu-dropdown').forEach(m => m.classList.remove('active'));
      if (!e.target.closest('.user-menu')) document.getElementById('userDropdown').style.display = 'none';
    };

    init();
  </script>
</body>
</html>
